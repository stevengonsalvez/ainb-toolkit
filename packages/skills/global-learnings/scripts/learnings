#!/usr/bin/env bash
# learnings - Global Learnings CLI wrapper
#
# Manages a uv virtualenv at $REPO_DIR/.venv/ and runs the Python CLI.
# Auto-creates the global learnings repo structure on first run.

set -euo pipefail

LEARNINGS_HOME="${LEARNINGS_HOME:-$HOME/.learnings}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$LEARNINGS_HOME"
VENV_DIR="$REPO_DIR/.venv"
CLI_SCRIPT="$SCRIPT_DIR/learnings_cli.py"
REQUIREMENTS="$SCRIPT_DIR/requirements.txt"
STAMP_FILE="$VENV_DIR/.deps-installed"

# --- Utilities ---

ensure_uv() {
    if command -v uv &>/dev/null; then return 0; fi
    for p in "$HOME/.local/bin/uv" "$HOME/.cargo/bin/uv" "/usr/local/bin/uv"; do
        if [[ -x "$p" ]]; then
            eval "uv() { \"$p\" \"\$@\"; }"
            return 0
        fi
    done
    echo "Error: uv is not installed." >&2
    echo "Install: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
    echo "Or:      brew install uv" >&2
    exit 1
}

ensure_venv() {
    if [[ ! -d "$VENV_DIR" ]]; then
        echo "Creating virtualenv at $VENV_DIR ..." >&2
        uv venv "$VENV_DIR" --python 3.11 2>/dev/null \
            || uv venv "$VENV_DIR" 2>/dev/null \
            || { echo "Error: failed to create virtualenv." >&2; exit 1; }
    fi
}

ensure_deps() {
    # Skip if stamp file is newer than requirements.txt
    if [[ -f "$STAMP_FILE" && "$STAMP_FILE" -nt "$REQUIREMENTS" ]]; then
        return 0
    fi
    echo "Installing dependencies ..." >&2
    # nano-graphrag installed separately with --no-deps to avoid broken
    # transitive chain: graspologic -> hyppo -> numba -> llvmlite (Python <3.10)
    uv pip install nano-graphrag --no-deps --python "$VENV_DIR/bin/python" --quiet 2>&1 >&2
    uv pip install -r "$REQUIREMENTS" --python "$VENV_DIR/bin/python" --quiet 2>&1 >&2
    touch "$STAMP_FILE"
}

ensure_model() {
    # Check if the embedding model is already cached
    local model_dir
    model_dir="$(find "$HOME/.cache" -type d -name "sentence-transformers_all-mpnet-base-v2" 2>/dev/null | head -1)"
    if [[ -z "$model_dir" ]]; then
        echo "Downloading embedding model (~420MB, one-time) ..." >&2
        "$VENV_DIR/bin/python" -c \
            "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-mpnet-base-v2')" \
            2>/dev/null \
            || echo "Warning: Model download failed. Search requires internet for first run." >&2
    fi
}

auto_init() {
    # Create repo directory structure if missing
    if [[ ! -d "$REPO_DIR/documents" ]]; then
        mkdir -p "$REPO_DIR/documents/learnings" \
                 "$REPO_DIR/documents/episodes" \
                 "$REPO_DIR/documents/clusters" \
                 "$REPO_DIR/nano_graphrag_cache"
    fi
    # Initialize git repo if missing
    if [[ ! -d "$REPO_DIR/.git" ]]; then
        git -C "$REPO_DIR" init >/dev/null 2>&1
        if [[ ! -f "$REPO_DIR/.gitignore" ]]; then
            cat > "$REPO_DIR/.gitignore" <<'GITIGNORE'
.venv/
__pycache__/
*.pyc
nano_graphrag_cache/
GITIGNORE
        fi
        git -C "$REPO_DIR" add . >/dev/null 2>&1
        git -C "$REPO_DIR" commit -m "Initialize global learnings" --quiet 2>/dev/null || true
    fi
}

# --- Main ---

ensure_uv
auto_init
ensure_venv
ensure_deps

# Only download embedding model for commands that actually need it
case "${1:-}" in
    search|reindex|critical-patterns)
        ensure_model
        ;;
esac

export LEARNINGS_HOME
exec "$VENV_DIR/bin/python" "$CLI_SCRIPT" "$@"
